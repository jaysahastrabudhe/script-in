{
  "version": 2,
  "builds": [
    { "src": "api/contact.js", "use": "@vercel/node" },
    { "src": "api/quote.js",   "use": "@vercel/node" },
    { "src": "index.html",     "use": "@vercel/static" },
    { "src": "samples/*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/contact",    "dest": "/api/contact.js" },
    { "src": "/api/quote",      "dest": "/api/quote.js" },
    { "src": "/samples/(.*)",   "dest": "/samples/$1" },
    { "src": "/(.*)",           "dest": "/index.html" }
  ]
}
